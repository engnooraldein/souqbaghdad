                       "artifacts/*",
                       "lib/*",
                       "scripts"
                   ],
    "private":  true,
    "devDependencies":  {
                            "prettier":  "^3.8.3",
                            "typescript":  "~5.9.3"
                        },
    "packageManager":  "pnpm@9.1.0"
}
