{
    "name":  "workspace",
    "version":  "0.0.0",
    "license":  "MIT",
    "engines":  {
                    "node":  "\u003e=20.0.0"
                },
    "scripts":  {
                    "dev":  "npm run dev --workspace=@workspace/souq-baghdad",
