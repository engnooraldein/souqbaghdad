{
  "framework": "vite",
  "buildCommand": "npx vite build --config artifacts/souq-baghdad/vite.config.ts",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile --ignore-scripts",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
